# =============================================================================
# Переменные окружения — скопируйте в .env и при необходимости измените
# =============================================================================

# --- PostgreSQL ---
# DSN для приложения (runtime). Используется обычный пользователь `pacs_app`.
DATABASE_URL=postgresql+asyncpg://pacs:pacs_secret@localhost:5432/pacs_ris

# DSN для миграций Alembic. Имеет права на DDL.
DATABASE_MIGRATION_URL=postgresql+asyncpg://pacs_migrator:pacs_migrator_secret@localhost:5432/pacs_ris

# Синхронный DSN (для скриптов, где async не нужен — например, alembic CLI в sync-режиме)
DATABASE_SYNC_URL=postgresql+psycopg://pacs:pacs_secret@localhost:5432/pacs_ris

# --- JWT / безопасность ---
# Секрет для подписи JWT. В ПРОДЕ обязательно: `openssl rand -hex 32`
JWT_SECRET=change-me-in-production-please-this-is-not-secure-at-all
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=7

# --- Сервисы ---
ORTHANC_URL=http://localhost:8042
RIS_URL=http://localhost:8000
ELQUEUE_URL=http://localhost:8005

# --- Серверы ---
RIS_PORT=8000
ELQUEUE_PORT=8005
